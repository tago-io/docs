{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "ignorePatterns": [
    "node_modules",
    "build",
    ".docusaurus",
    "infra",
    "cdk",
    "cdk.out",
    ".crush",
    ".claude",
    ".mdx",
    "lib"
  ]
}
