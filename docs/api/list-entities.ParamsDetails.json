{
  "parameters": [
    {
      "name": "page",
      "in": "query",
      "schema": { "type": "string", "example": "number" },
      "description": "(default 1)"
    },
    {
      "name": "amount",
      "in": "query",
      "schema": { "type": "string", "example": "number" },
      "description": "(default: 20, max: 100)"
    },
    { "name": "filter", "in": "query", "schema": { "type": "string", "example": "[name]" }, "description": "string" },
    { "name": "orderBy", "in": "query", "schema": { "type": "string", "example": "created_at | updated_at" } },
    {
      "name": "fields",
      "in": "query",
      "schema": { "type": "string" },
      "description": "comma-separated list of fields to return"
    }
  ]
}
