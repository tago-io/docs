            "value": "[\n    {\n        \"id\": \"6298fcc3e0b6840012bb6abfa\",\n        \"value\": \"27\", // edit the value field\n        \"metadata\": { // edit the metadata field\n            \"color\": \"blue\"\n        }\n    }\n]"
          }
        }
      }
    }
  }
