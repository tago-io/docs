{
  "parameters": [
    {
      "name": "page",
      "in": "query",
      "schema": { "type": "string", "example": "number" },
      "description": "(default 1)"
    },
    {
      "name": "amount",
      "in": "query",
      "schema": { "type": "string", "example": "number" },
      "description": "(default: 20, max: 1000)"
    },
    {
      "name": "fields",
      "in": "query",
      "schema": { "type": "string", "example": "" },
      "description": "comma-separated list of fields to return"
    },
    { "name": "order_by", "in": "query", "schema": { "type": "string", "example": "asc/desc" } },
    {
      "name": "filter",
      "in": "query",
      "schema": { "type": "string", "example": "" },
      "description": "JSON object. Filter by an entity field. Requires the index paramenter"
    },
    {
      "name": "index",
      "in": "query",
      "required": true,
      "schema": { "type": "string" },
      "description": "First index searchable field from the entity field added to the filter parameter"
    },
    {
      "name": "entity_id",
      "in": "path",
      "required": true,
      "schema": { "type": "string", "example": "(Type an entity ID)" }
    }
  ]
}
