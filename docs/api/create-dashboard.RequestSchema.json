                "type": "object",
                "properties": {
                  "key": { "type": "string", "example": "vehicle" },
                  "value": { "type": "string", "example": "gas" }
                }
              },
              "example": [
                { "key": "vehicle", "value": "gas" },
                { "key": "speed", "value": "mph" }
