                "properties": {
                  "key": { "type": "string", "example": "my_tag_key" },
                  "value": { "type": "string", "example": "my_tag_value" }
                }
              },
              "example": [{ "key": "my_tag_key", "value": "my_tag_value" }]
            },
            "visible": { "type": "boolean", "example": false }
          }
        },
        "examples": {
          "Edit device": {
            "value": {
              "active": false,
              "connector": "6148de43683cae0018940d0c",
              "name": "Device #2",
              "network": "5bbd120d4051a50034cd1a05",
              "payload_decoder": "",
              "tags": [{ "key": "my_tag_key", "value": "my_tag_value" }],
              "visible": false,
              "chunk_retention": 20
            }
          },
          "Immutable Chunk retention": {
            "value": "{\r\n    \"chunk_retention\": 20 // acceptable range by period: day(0-31), week(0-26), month(0-36), quarter(0-36)\r\n}"
          }
        }
      }
    }
  }
