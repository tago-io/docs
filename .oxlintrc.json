{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "settings": {
    "react": {
      "version": "18.3"
    }
  },
  "ignorePatterns": [
    "node_modules",
    "build",
    ".docusaurus",
    "infra",
    "cdk",
    "cdk.out",
    ".crush",
    ".claude",
    ".mdx",
    "lib"
  ]
}
